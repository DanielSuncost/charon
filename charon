#!/usr/bin/env bash
# charon — Launch the Charon Agent Operating System
#
# Usage:
#   charon              Start the TUI
#   charon chat         Direct CLI chat (no TUI)
#   charon setup        Run setup/onboarding
#   charon status       Show current config
#   charon agents       List agents
#   charon --help       Show help

set -euo pipefail

# Resolve symlinks to find the real project root
SOURCE="${BASH_SOURCE[0]}"
while [ -L "$SOURCE" ]; do
  DIR="$(cd "$(dirname "$SOURCE")" && pwd)"
  SOURCE="$(readlink "$SOURCE")"
  [[ $SOURCE != /* ]] && SOURCE="$DIR/$SOURCE"
done
CHARON_ROOT="$(cd "$(dirname "$SOURCE")" && pwd)"
RUST_TUI_MANIFEST="${CHARON_ROOT}/crates/charon-tui/Cargo.toml"
RUST_TUI_BIN="${CHARON_ROOT}/crates/charon-tui/target/release/charon"

# Activate project venv if it exists
if [ -d "${CHARON_ROOT}/.venv" ]; then
  export VIRTUAL_ENV="${CHARON_ROOT}/.venv"
  export PATH="${CHARON_ROOT}/.venv/bin:${PATH}"
fi

# Subcommands that don't launch the TUI
case "${1:-}" in
  chat)
    shift
    exec python3 "${CHARON_ROOT}/scripts/charon_chat.py" "$@"
    ;;
  setup)
    shift
    exec python3 "${CHARON_ROOT}/scripts/charon_agents.py" setup "$@"
    ;;
  status)
    exec python3 "${CHARON_ROOT}/scripts/charon_agents.py" setup status
    ;;
  agents|list)
    exec python3 "${CHARON_ROOT}/scripts/charon_agents.py" list
    ;;
  --help|-h|help)
    echo "Charon — Agent Operating System"
    echo ""
    echo "Usage:"
    echo "  charon                       Launch the TUI (fresh session)"
    echo "  charon --resume              Resume most recent session"
    echo "  charon --agent AG-0005       New session bound to a specific agent"
    echo "  charon --provider codex      Start with a specific provider"
    echo "  charon chat                  Direct CLI chat (no TUI)"
    echo "  charon setup                 Run setup/onboarding"
    echo "  charon status                Show current config"
    echo "  charon agents                List agents"
    echo ""
    echo "TUI Controls (Rust TUI):"
    echo "  F1  Chat view"
    echo "  F2  Dashboard"
    echo "  F3  Session Grid"
    exit 0
    ;;
esac

# Parse TUI flags (all fall through to TUI launch)
LAUNCH_TUI=1
while [[ $# -gt 0 ]]; do
  case "$1" in
    --resume=*)
      export CHARON_RESUME="${1#--resume=}"
      shift
      ;;
    --resume)
      export CHARON_RESUME="${2:-latest}"
      shift; shift
      ;;
    --agent=*)
      export CHARON_AGENT="${1#--agent=}"
      shift
      ;;
    --agent)
      export CHARON_AGENT="${2:-}"
      shift; shift
      ;;
    --provider=*)
      export CHARON_PROVIDER="${1#--provider=}"
      shift
      ;;
    --provider)
      export CHARON_PROVIDER="${2:-}"
      shift; shift
      ;;
    claude-code|codex|lmstudio|opencode|api)
      export CHARON_PROVIDER="$1"
      shift
      ;;
    --tmux)
      export CHARON_USE_TMUX=1
      shift
      ;;
    --no-tmux)
      export CHARON_NO_TMUX=1
      shift
      ;;
    *)
      # Unknown flag — pass through to charon_agents.py
      exec python3 "${CHARON_ROOT}/scripts/charon_agents.py" "$@"
      ;;
  esac
done

# Launch Rust TUI
if ! command -v cargo &>/dev/null; then
  echo "Error: cargo is required to build/run the Rust TUI."
  echo "Install Rust: https://rustup.rs"
  echo ""
  echo "Alternatively, use CLI mode: charon chat"
  exit 1
fi

# Check Python deps used by the backend pieces the Rust TUI relies on.
if ! python3 -c "import httpx" 2>/dev/null; then
  echo "Python dependencies missing. Run: ./scripts/install-dev.sh"
  exit 1
fi

# Build Rust TUI if needed
if [ ! -x "${RUST_TUI_BIN}" ]; then
  echo "Building Rust TUI..."
  cargo build --release --manifest-path "${RUST_TUI_MANIFEST}"
fi

if [ ! -x "${RUST_TUI_BIN}" ]; then
  echo "Error: Rust TUI binary not found after build: ${RUST_TUI_BIN}"
  exit 1
fi

exec "${RUST_TUI_BIN}" "$@"
