#!/usr/bin/env bash
# charons-boat — Universal agent session bridge for Charon
set -euo pipefail

BOAT_DIR="${HOME}/.charon/boats"
BOAT_KEYS="${HOME}/.charon/boat-keys"
SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"

mkdir -p "$BOAT_DIR" "$BOAT_KEYS" 2>/dev/null || true

generate_code() {
  local part1 part2
  part1=$(head -c 4 /dev/urandom | xxd -p | tr '[:lower:]' '[:upper:]' | head -c 4)
  part2=$(head -c 4 /dev/urandom | xxd -p | tr '[:lower:]' '[:upper:]' | head -c 4)
  echo "CHARON-${part1}-${part2}"
}

cmd_wrap() {
  local name=""
  local attach_current=0
  local cmd_args=()
  while [[ $# -gt 0 ]]; do
    case "$1" in
      --name) name="$2"; shift 2 ;;
      --attach) attach_current=1; shift ;;
      --) shift; cmd_args=("$@"); break ;;
      *) cmd_args=("$@"); break ;;
    esac
  done

  if [ ${#cmd_args[@]} -eq 0 ]; then
    echo "Usage: charons-boat wrap [--name NAME] -- <command> [args...]"
    exit 1
  fi

  if [ -z "$name" ]; then
    name="$(echo "${cmd_args[0]}" | tr -cd '[:alnum:]-' | head -c 20)-$$"
  fi

  local session_name="boat-${name}"
  if [ "$attach_current" != "1" ]; then
    echo "⛵ Starting PTY boat session: ${session_name}"
  fi
  nohup python3 "${SCRIPT_DIR}/boat_session.py" --name "$name" -- "${cmd_args[@]}" \
    >"${BOAT_DIR}/${session_name}.log" 2>&1 &
  local launcher_pid=$!

  # Wait briefly for registry/socket creation.
  local reg_file="${BOAT_DIR}/${session_name}.json"
  for _ in $(seq 1 50); do
    if [ -f "$reg_file" ]; then
      break
    fi
    sleep 0.1
  done

  if [ "$attach_current" = "1" ]; then
    exec python3 "${SCRIPT_DIR}/boat_attach.py" "$session_name"
  fi
  echo "⛵ Session started in background (launcher pid ${launcher_pid})"
  echo "  name:    ${name}"
  echo "  session: ${session_name}"
  echo "  log:     ${BOAT_DIR}/${session_name}.log"
  echo "  Open Charon F3 to view/interact with it."
}

cmd_attach() {
  if [ -z "${1:-}" ]; then
    echo "Usage: charons-boat attach <session>"
    exit 1
  fi
  exec python3 "${SCRIPT_DIR}/boat_attach.py" "$1"
}

cmd_serve() {
  local code=""
  local gen_code=false
  while [[ $# -gt 0 ]]; do
    case "$1" in
      --generate-code) gen_code=true; shift ;;
      --code) code="$2"; shift 2 ;;
      --from-extension) shift ;;
      *) shift ;;
    esac
  done

  if $gen_code || [ -z "$code" ]; then
    code=$(generate_code)
  fi
  echo "$code" > "${BOAT_KEYS}/current-code"
  chmod 600 "${BOAT_KEYS}/current-code"

  echo "⛵ charons-boat active"
  echo ""
  echo "  Pairing code: ${code}"
  echo ""
  echo "  On your local Charon, run:"
  echo "    /link $(whoami)@$(hostname) --code ${code}"
}

cmd_status() {
  echo "⛵ charons-boat status"
  echo ""
  if [ -d "$BOAT_DIR" ] && ls "$BOAT_DIR"/*.json >/dev/null 2>&1; then
    echo "  Registered sessions:"
    for f in "$BOAT_DIR"/*.json; do
      python3 - <<PY
import json
from pathlib import Path
p = Path(${f@Q})
try:
    reg = json.loads(p.read_text())
except Exception:
    reg = {}
name = reg.get('name', '?')
session = reg.get('session', p.stem)
status = reg.get('status', '?')
transport = reg.get('transport', 'unknown')
print(f"    {name} → {transport}:{session} ({status})")
PY
    done
  else
    echo "  No registered sessions"
  fi
}

cmd_revoke() {
  rm -rf "$BOAT_KEYS"/*
  echo "⛵ All pairing keys revoked"
}

cmd_deploy() {
  local target="${1:-}"
  if [ -z "$target" ]; then
    echo "Usage: charons-boat deploy user@host"
    exit 1
  fi

  local remote_bin="\$HOME/.local/bin"
  local files=(
    "${SCRIPT_DIR}/charons-boat"
    "${SCRIPT_DIR}/boat_session.py"
    "${SCRIPT_DIR}/boat_stream.py"
    "${SCRIPT_DIR}/boat_attach.py"
    "${SCRIPT_DIR}/harbor_worker.py"
  )

  echo "⛵ Deploying charons-boat to ${target}..."

  # Create remote directory
  ssh "$target" "mkdir -p ${remote_bin}" || { echo "Failed to create remote directory"; exit 1; }

  # Copy files
  scp "${files[@]}" "${target}:${remote_bin}/" || { echo "Failed to copy files"; exit 1; }

  # Make executable
  ssh "$target" "chmod +x ${remote_bin}/charons-boat" || { echo "Failed to set permissions"; exit 1; }

  # Verify
  local version
  version=$(ssh "$target" "${remote_bin}/charons-boat version 2>/dev/null || echo 'installed'")
  echo "⛵ Deployed successfully: ${version}"
  echo "  Remote path: ${remote_bin}/charons-boat"
  echo ""
  echo "  Ensure ${remote_bin} is in PATH on the remote host:"
  echo "    ssh ${target} 'echo \"export PATH=\\\"\\\$HOME/.local/bin:\\\$PATH\\\"\" >> ~/.bashrc'"
}

cmd_version() {
  echo "charons-boat 0.1.0"
}

case "${1:-help}" in
  wrap) shift; cmd_wrap "$@" ;;
  attach) shift; cmd_attach "$@" ;;
  serve) shift; cmd_serve "$@" ;;
  status) cmd_status ;;
  revoke) cmd_revoke ;;
  deploy) shift; cmd_deploy "$@" ;;
  version|--version) cmd_version ;;
  stream) shift; exec python3 "${SCRIPT_DIR}/boat_stream.py" "$@" ;;
  harbor) shift; exec python3 "${SCRIPT_DIR}/harbor_worker.py" "$@" ;;
  help|--help|-h)
    echo "charons-boat — Universal agent session bridge for Charon"
    echo ""
    echo "Usage:"
    echo "  charons-boat wrap [--name NAME] [--attach] -- <command>  Wrap command in a PTY"
    echo "  charons-boat attach <session>                 Attach current terminal to a PTY boat session"
    echo "  charons-boat stream                           Stream PTY sessions (JSON over stdio)"
    echo "  charons-boat harbor                           Harbor protocol worker (structured task dispatch)"
    echo "  charons-boat serve [--generate-code]          Start for remote access"
    echo "  charons-boat deploy user@host                 Install boat on a remote server"
    echo "  charons-boat status                           Show status"
    echo "  charons-boat revoke                           Revoke pairing keys"
    echo "  charons-boat version                          Show version"
    echo ""
    echo "Examples:"
    echo "  charons-boat wrap -- pi"
    echo "  charons-boat wrap --name myhermes -- hermes"
    echo "  charons-boat deploy dan@gpu-box"
    ;;
  *) echo "Unknown command: $1. Run 'charons-boat help' for usage."; exit 1 ;;
esac
